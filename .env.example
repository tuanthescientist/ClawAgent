# Environment Configuration
ENV=development
DEBUG=True
LOG_LEVEL=INFO

# OpenAI Configuration (Primary)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# ChatGPT via Browser (Alternative/Secondary)
# Get token from browser console: fetch('https://chat.openai.com/api/auth/session').then(r=>r.json()).then(d=>console.log(d.accessToken))
CHATGPT_ACCESS_TOKEN=optional_chatgpt_token

# Local LLM Configuration (Via Ollama)
USE_LOCAL_LLM=False
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=mistral

# WhatsApp Configuration (Twilio - Optional)
TWILIO_ACCOUNT_SID=optional_account_sid
TWILIO_AUTH_TOKEN=optional_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
WHATSAPP_WEBHOOK_TOKEN=optional_webhook_secret
